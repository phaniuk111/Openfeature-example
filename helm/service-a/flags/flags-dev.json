{
  "$schema": "https://flagd.dev/schema/v0/flags.json",
  "flags": {
    "new-ui": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "on"
    },
    "dataflow-batch-size": {
      "state": "ENABLED",
      "variants": {
        "small": 150,
        "large": 900
      },
      "defaultVariant": "small"
    },
    "welcome-banner": {
      "state": "ENABLED",
      "variants": {
        "value": "Service A - dev"
      },
      "defaultVariant": "value"
    },
    "checkout-v2": {
      "state": "ENABLED",
      "variants": {
        "on": true,
        "off": false
      },
      "defaultVariant": "off"
    }
  }
}
